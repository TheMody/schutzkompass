# ─── Application ───────────────────────────────────────
NODE_ENV=development

# ─── Database (PostgreSQL) ─────────────────────────────
DATABASE_URL=postgresql://schutzkompass:schutzkompass_dev@localhost:5432/schutzkompass

# ─── Redis ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── MinIO (S3-compatible storage) ─────────────────────
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=schutzkompass

# ─── Authentication ────────────────────────────────────
AUTH_SECRET=change-me-to-a-random-secret-at-least-32-chars
NEXTAUTH_URL=http://localhost:3000

# ─── Email (Resend) ───────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# ─── NVD API ──────────────────────────────────────────
NVD_API_KEY=

# ─── Internal (Worker ↔ Web communication) ────────────
INTERNAL_TOKEN=change-me-to-a-random-internal-token
